# Hermes Agent 环境变量模板
# 复制为 .env 并填入你的 API Key

# ===== 模型提供商 (至少填一个) =====
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 商汤 SenseNova
SENSENOVA_API_KEY=your-sensenova-key
SN_API_KEY=your-sn-key

# Agnes AI
AGNES_AI_API_KEY=your-agnes-ai-key

# 可选: SiliconFlow
SILICONFLOW_KEY=your-siliconflow-key

# ===== 微信网关 (如不需要可跳过) =====
WEIXIN_ACCOUNT_ID=
WEIXIN_TOKEN=
WEIXIN_BASE_URL=
WEIXIN_CDN_BASE_URL=
WEIXIN_DM_POLICY=
WEIXIN_ALLOW_ALL_USERS=
WEIXIN_HOME_CHANNEL=
